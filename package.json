{
  "name": "canoe-hunter",
  "version": "1.0.0",
  "description": "Monitor Craigslist canoe listings near Hudson, NY and alert on strong matches.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:fresh": "tsx src/index.ts --reset",
    "build": "tsc",
    "start": "node dist/index.js",
    "run-once": "tsx src/index.ts --once",
    "reset": "tsx src/index.ts --reset-only",
    "reset-and-run": "tsx src/index.ts --reset --once",
    "rescore": "tsx scripts/recompute-scores.ts"
  },
  "dependencies": {
    "@types/pdfkit": "^0.17.6",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.6",
    "openai": "^6.34.0",
    "pdfkit": "^0.18.0",
    "twilio": "^6.0.0",
    "zipcodes": "^8.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/zipcodes": "^8.0.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
